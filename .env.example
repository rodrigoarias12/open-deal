# NOTE: wrap any value containing '#' in double quotes, otherwise dotenv
# treats '#' as start-of-comment and truncates the value.
# Example: ODOO_PASSWORD="pa#ssword"

# LLM: leave ANTHROPIC_API_KEY empty to use AWS Bedrock instead.
# Selection precedence:
#   1. LLM_PROVIDER=bedrock|anthropic (explicit)
#   2. ANTHROPIC_API_KEY set → anthropic
#   3. AWS_REGION or AWS_PROFILE set → bedrock
#   4. otherwise → anthropic (will throw if key missing)
ANTHROPIC_API_KEY=
# AWS Bedrock (alternative to Anthropic API key):
# AWS creds resolve via standard AWS SDK chain (env, ~/.aws, SSO, IAM role).
AWS_REGION=us-east-1
# AWS_PROFILE=default
BEDROCK_MODEL=us.anthropic.claude-sonnet-4-6

SEPOLIA_RPC_URL=

AGENT_PRIVATE_KEY=

UNISWAP_API_KEY=

ENS_NAME=

ODOO_URL=
ODOO_DB=
ODOO_USERNAME=
ODOO_PASSWORD=

# 0G (Galileo testnet, chainId 16602). Optional — defaults work for testnet.
# AGENT_PRIVATE_KEY above is reused for 0G Chain (same EVM key).
ZG_RPC_URL=
ZG_INDEXER_URL=
# Address of the deployed AuditAnchor contract on 0G Chain.
# See contracts/AuditAnchor.deployment.json for the active deployment.
ZG_AUDIT_ANCHOR=
