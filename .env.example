# NOTE: wrap any value containing '#' in double quotes, otherwise dotenv
# treats '#' as start-of-comment and truncates the value.
# Example: ODOO_PASSWORD="pa#ssword"

# LLM: leave ANTHROPIC_API_KEY empty to use AWS Bedrock instead.
# Selection precedence:
#   1. LLM_PROVIDER=bedrock|anthropic (explicit)
#   2. ANTHROPIC_API_KEY set → anthropic
#   3. AWS_REGION or AWS_PROFILE set → bedrock
#   4. otherwise → anthropic (will throw if key missing)
ANTHROPIC_API_KEY=
# AWS Bedrock (alternative to Anthropic API key):
# AWS creds resolve via standard AWS SDK chain (env, ~/.aws, SSO, IAM role).
AWS_REGION=us-east-1
# AWS_PROFILE=default
BEDROCK_MODEL=us.anthropic.claude-sonnet-4-6

SEPOLIA_RPC_URL=

AGENT_PRIVATE_KEY=

UNISWAP_API_KEY=

# ENS name owned by the agent. Holds the policy records the agent reads
# before each onchain action. Sepolia ENS works the same as mainnet —
# the registry lives at the same 0x00…2e1e address.
ENS_NAME=openagents-treasury.eth
# RPC used to resolve ENS_NAME. Can be Sepolia (recommended for the demo;
# our agent name lives there) or mainnet. Auto-detects chain from the URL.
MAINNET_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

ODOO_URL=
ODOO_DB=
ODOO_USERNAME=
ODOO_PASSWORD=

# 0G (Galileo testnet, chainId 16602). Optional — defaults work for testnet.
# AGENT_PRIVATE_KEY above is reused for 0G Chain (same EVM key).
ZG_RPC_URL=
ZG_INDEXER_URL=
# Address of the deployed AuditAnchor contract on 0G Chain.
# See contracts/AuditAnchor.deployment.json for the active deployment.
ZG_AUDIT_ANCHOR=

# KeeperHub agentic wallet — funds x402 paid-RFQ replies in direct.v1
# settlement mode. Required for procurement.rfq-price > 0 sellers.
# Get the API key + funded wallet from https://keeperhub.io
# When set, keeperhub-rail/payX402Challenge() switches from mock receipts
# to real on-chain transfers via the KeeperHub-custodied wallet.
KEEPERHUB_API_KEY=
KEEPERHUB_WALLET=
# Cap (USDC) on what the buyer agent will pay per RFQ challenge. Sellers
# asking more than this get skipped per PROTOCOL.md §3.4 conformance.
MAX_RFQ_PRICE_USDC=0.01
